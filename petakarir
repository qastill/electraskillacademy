const state = {query:'',bidang:'all',level:'all',area:'all',selected:null};
const $ = (sel, el=document) => el.querySelector(sel);
const $$ = (sel, el=document) => [...el.querySelectorAll(sel)];
const escHtml = (s) => String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));

function filterOkupasi() {
  const q = state.query.toLowerCase();
  return DATA.okupasi.filter(o => {
    if (state.bidang !== 'all' && o.bidang !== state.bidang) return false;
    if (state.level !== 'all' && o.level !== parseInt(state.level)) return false;
    if (state.area !== 'all' && o.area_fungsi !== state.area) return false;
    if (q && !o.name.toLowerCase().includes(q)) return false;
    return true;
  });
}

function groupOkupasi(list) {
  const g = {};
  list.forEach(o => {
    if (!g[o.bidang]) g[o.bidang] = {};
    if (!g[o.bidang][o.level]) g[o.bidang][o.level] = [];
    g[o.bidang][o.level].push(o);
  });
  return g;
}

function render() {
  const filtered = filterOkupasi();
  const grouped = groupOkupasi(filtered);
  const bidangOrder = ['pembangkit', 'transmisi', 'distribusi', 'pemanfaatan'];
  const visibleBidang = bidangOrder.filter(b => grouped[b]);
  const html = renderHero() + renderStats() + renderFilters(filtered.length) +
    '<main class="container">' + (filtered.length === 0 ? renderEmpty() : visibleBidang.map(b => renderBidangSection(b, grouped[b])).join('')) + '</main>' +
    renderFooter() + renderModal();
  $('#app').innerHTML = html;
  attachListeners();
}

function renderHero() {
  return `
    <header class="hero">
      <div class="hero-grid"></div>
      <div class="container hero-inner">
        <div class="brand-line"><div class="dash"></div><span>Electra Skill Academy presents</span></div>
        <h1>
          <span class="line1">Peta Karir</span>
          <span class="line2">Ketenagalistrikan</span>
          <span class="line3">Indonesia</span>
        </h1>
        <div class="hero-sub"><div class="dash"></div><p>${escHtml(DATA.metadata.subtitle)}</p></div>
        <p class="hero-desc">
          Eksplorasi <strong>${DATA.metadata.total_okupasi} okupasi nasional</strong> di sektor ketenagalistrikan Indonesia — lengkap dengan detail tugas, skill wajib, tanggung jawab, dan wewenang. Terstruktur menurut KKNI Level 1 hingga 9.
        </p>
        <div class="hero-pills">
          <span class="pill">📘 ${escHtml(DATA.metadata.issuer)}</span>
          <span class="pill">📅 Edisi ${DATA.metadata.year}</span>
