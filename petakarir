          <h3>Wewenang</h3>
        </div>
        <div class="section-content">
          <ul>${d.wewenang.map(t => `<li>${escHtml(t)}</li>`).join('')}</ul>
        </div>
      </div>`);
  }
  
  // 6. Tugas Utama
  if (d.tugas_utama && d.tugas_utama.length > 0) {
    sections.push(`
      <div class="section">
        <div class="section-head">
          <span class="num">${secNum++}.</span>
          <span class="icon">⚙️</span>
          <h3>Tugas Utama</h3>
        </div>
        <div class="section-content">
          <ul>${d.tugas_utama.map(t => `<li>${escHtml(t)}</li>`).join('')}</ul>
        </div>
      </div>`);
  }
  
  // 7. Tugas Khusus
  if (d.tugas_khusus && d.tugas_khusus.length > 0) {
    sections.push(`
      <div class="section">
        <div class="section-head">
          <span class="num">${secNum++}.</span>
          <span class="icon">📐</span>
          <h3>Tugas Khusus</h3>
        </div>
        <div class="section-content">
          <ul>${d.tugas_khusus.map(t => `<li>${escHtml(t)}</li>`).join('')}</ul>
        </div>
      </div>`);
  }
  
  // 8. Persyaratan
  if (d.persyaratan && d.persyaratan.length > 0) {
    sections.push(`
      <div class="section">
        <div class="section-head">
          <span class="num">${secNum++}.</span>
          <span class="icon">🎓</span>
          <h3>Persyaratan Masuk / Jenjang Karir</h3>
        </div>
        <div class="section-content">
          <ul>${d.persyaratan.map(t => `<li>${escHtml(t)}</li>`).join('')}</ul>
        </div>
      </div>`);
  }
  
  const detailContent = sections.length > 0 
    ? sections.join('') 
    : '<div class="no-detail">Detail lengkap untuk okupasi ini sedang dilengkapi. Silakan rujuk halaman ' + o.page + ' di Buku Peta Okupasi 2018.</div>';
  
  return `
    <div class="modal-backdrop show" id="modal-backdrop">
      <div class="modal" onclick="event.stopPropagation()">
        <button class="modal-close" id="modal-close" aria-label="Tutup">✕</button>
        <div class="modal-body">
          <div class="modal-bidang">
            <span class="icon">${bidang.icon}</span>
            <span class="label">${escHtml(bidang.name)}</span>
          </div>
          <div class="modal-level-badge">
            <span class="kkni">${escHtml(level.kkni)}</span>
            <span class="sep"></span>
            <span class="label">${escHtml(level.label)}</span>
          </div>
          <h2>${escHtml(o.name)}</h2>
          <div class="modal-meta">
            <span class="chip">📁 ${escHtml(area)}</span>
            <span class="chip">📄 Hal. ${o.page}</span>
          </div>
          ${detailContent}
          <div class="tips-box">
            <h3>💡 Jalur Pengembangan</h3>
            <p>Okupasi ini berada pada <strong>${escHtml(level.kkni)}</strong>. Untuk naik ke level berikutnya, biasanya diperlukan kombinasi: penambahan jam pengalaman lapangan, sertifikasi BNSP/LSP yang relevan dengan area <em>${escHtml(area.toLowerCase())}</em>, dan pendidikan/pelatihan teknis lanjutan.</p>
            <p class="tips-note">* Persyaratan detail (unit kompetensi, kualifikasi pendidikan) tersedia di SKKNI Ketenagalistrikan yang diterbitkan Kemnaker.</p>
          </div>
          <div class="modal-footer">
            <p>Sumber: Buku Peta Okupasi Nasional Ketenagalistrikan 2018 — Kementerian ESDM</p>
            <button class="btn-close" id="btn-close-modal">Tutup</button>
          </div>
        </div>
      </div>
    </div>`;
}

