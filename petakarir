function attachListeners() {
  const searchInput = $('#search-input');
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      state.query = e.target.value;
      const clearBtn = $('#search-clear');
      if (clearBtn) clearBtn.classList.toggle('show', !!state.query);
      const cnt = filterOkupasi().length;
      const rc = $('.result-count');
      if (rc) rc.innerHTML = `<strong>${cnt}</strong> dari ${DATA.metadata.total_okupasi} okupasi`;
      const resetBtn = $('#reset-btn');
      if (resetBtn) {
        const hasFilter = state.query || state.bidang !== 'all' || state.level !== 'all' || state.area !== 'all';
        resetBtn.classList.toggle('show', hasFilter);
      }
      renderGridOnly();
    });
  }
  $('#search-clear')?.addEventListener('click', () => { state.query = ''; render(); });
  $('#filter-bidang')?.addEventListener('change', (e) => { state.bidang = e.target.value; render(); });
  $('#filter-level')?.addEventListener('change', (e) => { state.level = e.target.value; render(); });
  $('#filter-area')?.addEventListener('change', (e) => { state.area = e.target.value; render(); });
  $('#reset-btn')?.addEventListener('click', () => {
    state.query=''; state.bidang='all'; state.level='all'; state.area='all';
    render();
  });
  $('#modal-close')?.addEventListener('click', closeModal);
  $('#btn-close-modal')?.addEventListener('click', closeModal);
  $('#modal-backdrop')?.addEventListener('click', closeModal);
  attachCardListeners();
}

function attachCardListeners() {
  $$('.card').forEach(card => {
    card.addEventListener('click', () => {
      const name = card.dataset.name;
      const found = DATA.okupasi.find(o => o.name === name);
      if (found) { state.selected = found; render(); }
    });
  });
}

function renderGridOnly() {
  const filtered = filterOkupasi();
  const grouped = groupOkupasi(filtered);
  const bidangOrder = ['pembangkit', 'transmisi', 'distribusi', 'pemanfaatan'];
  const visibleBidang = bidangOrder.filter(b => grouped[b]);
  const main = $('main');
  if (main) {
    main.innerHTML = filtered.length === 0 ? renderEmpty() : visibleBidang.map(b => renderBidangSection(b, grouped[b])).join('');
    attachCardListeners();
  }
}

function closeModal() {
  state.selected = null;
  document.body.style.overflow = '';
  render();
}

document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && state.selected) closeModal(); });
render();
</script>
