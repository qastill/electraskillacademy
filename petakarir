          <span class="pill">💼 Klik kartu untuk detail lengkap</span>
        </div>
      </div>
    </header>`;
}

function renderStats() {
  const bidangEntries = Object.entries(DATA.bidang).filter(([k]) => k !== 'umum');
  return `
    <section class="stats"><div class="container stats-inner"><div class="stats-grid">
      ${bidangEntries.map(([key, meta]) => {
        const count = DATA.stats.by_bidang[key] || 0;
        return `<div><div class="stat-icon">${meta.icon}</div><div class="stat-num">${count}</div><div class="stat-label">${escHtml(meta.name)}</div></div>`;
      }).join('')}
    </div></div></section>`;
}

function renderFilters(resultCount) {
  const hasFilter = state.query || state.bidang !== 'all' || state.level !== 'all' || state.area !== 'all';
  return `
    <section class="filter"><div class="container filter-inner">
      <div class="search">
        <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        <input id="search-input" type="text" placeholder="Cari okupasi... (contoh: APP, kWh, gardu distribusi)" value="${escHtml(state.query)}">
        <button class="search-clear ${state.query?'show':''}" id="search-clear">✕</button>
      </div>
      <div class="filters-row">
        <select class="filter-select" id="filter-bidang" aria-label="Bidang">
          <option value="all">Semua Bidang</option>
          ${Object.entries(DATA.bidang).filter(([k])=>k!=='umum').map(([k,v]) => `<option value="${k}" ${state.bidang===k?'selected':''}>${v.icon} ${escHtml(v.name)}</option>`).join('')}
        </select>
        <select class="filter-select" id="filter-level" aria-label="Level KKNI">
          <option value="all">Semua Level</option>
          ${Object.entries(DATA.levels).sort((a,b)=>parseInt(b[0])-parseInt(a[0])).map(([k,v]) => `<option value="${k}" ${state.level===k?'selected':''}>${v.kkni} — ${escHtml(v.label)}</option>`).join('')}
        </select>
        <select class="filter-select" id="filter-area" aria-label="Area Fungsi">
          <option value="all">Semua Area</option>
          ${Object.entries(DATA.area_fungsi).map(([k,v]) => `<option value="${k}" ${state.area===k?'selected':''}>${escHtml(v)}</option>`).join('')}
        </select>
        <button class="reset-btn ${hasFilter?'show':''}" id="reset-btn">Reset semua</button>
        <div class="result-count"><strong>${resultCount}</strong> dari ${DATA.metadata.total_okupasi} okupasi</div>
      </div>
    </div></section>`;
}

function renderBidangSection(bidangKey, levels) {
  const bidang = DATA.bidang[bidangKey];
  if (!bidang) return '';
  const sortedLevels = Object.keys(levels).sort((a,b) => parseInt(b)-parseInt(a));
  return `
    <div class="bidang-section">
      <div class="bidang-header">
        <div class="top"><span class="icon">${bidang.icon}</span><span class="label">Bidang</span></div>
        <h2>${escHtml(bidang.name)}</h2>
        <p>${escHtml(bidang.description)}</p>
      </div>
      ${sortedLevels.map(lvKey => {
        const level = DATA.levels[lvKey];
        const items = levels[lvKey];
        return `
          <div class="level-block">
            <div class="level-head">
              <div class="kkni">${escHtml(level.kkni)}</div>
              <div class="name">${escHtml(level.label)}</div>
              <div class="divider"></div>
              <div class="count">${items.length} okupasi</div>
            </div>
            <div class="cards">${items.map((o, idx) => renderCard(o, idx)).join('')}</div>
          </div>`;
      }).join('')}
    </div>`;
}

function renderCard(o, idx) {
  const areaLabel = DATA.area_fungsi[o.area_fungsi]?.split(' ')[0] || o.area_fungsi;
  return `
    <button class="card area-${o.area_fungsi}" data-name="${escHtml(o.name)}">
      <div class="card-top">
        <span class="card-badge area-${o.area_fungsi}">${escHtml(areaLabel)}</span>
        <span class="card-page">hal. ${o.page}</span>
      </div>
      <p class="card-name">${escHtml(o.name)}</p>
      <div class="card-arrow"><span>Lihat detail</span><span class="arr">→</span></div>
    </button>`;
}

function renderEmpty() {
  return `<div class="empty"><h3>Tidak ada okupasi ditemukan</h3><p>Coba ubah filter atau kata kunci pencarian.</p></div>`;
}

